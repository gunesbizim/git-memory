{
  "mcpServers": {
    "git-memory": {
      "command": "git-memory",
      "args": ["serve"],
      "env": {
        "GIT_MEMORY_REPO_PATH": "/path/to/repo",
        "GIT_MEMORY_USER_ID": "my-repo-name",
        "GIT_MEMORY_EMBED_PROVIDER": "ollama",
        "GIT_MEMORY_EMBED_MODEL": "nomic-embed-text",
        "GIT_MEMORY_LLM_MODEL": "qwen2.5",
        "OLLAMA_URL": "http://localhost:11434"
      }
    }
  }
}
